│   ├── useUser.test.ts
│   └── useForm.test.ts
├── stores/                  # Store tests
│   ├── user.test.ts
│   └── auth.test.ts
├── services/                # Service tests
│   ├── userService.test.ts
│   └── apiService.test.ts
└── utils/                   # Utility function tests
    ├── validation.test.ts
    └── dateUtils.test.ts
```

