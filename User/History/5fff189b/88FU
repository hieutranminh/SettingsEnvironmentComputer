# Default Environment Configuration (fallback when no mode-specific .env is loaded)
# This file is used when running without --mode flag

# Application Configuration
VITE_APP_NAME="Ahasoft System"
VITE_APP_VERSION="1.0.0"
VITE_APP_ENV="localhost"

# Gateway & API Configuration
VITE_GATEWAY_BASE_URL="https://localhost:59001"
VITE_API_TIMEOUT=30000

# OAuth Configuration (GitLab)
# GitLab OAuth authorization endpoint
VITE_OAUTH2_AUTHORIZE_URL="https://gitlab.com/oauth/authorize"
# GitLab OAuth application client ID (registered in GitLab > Settings > Applications)
VITE_OAUTH2_CLIENT_ID="4356fae6ec3e76eedab68d107af246136ccd188daf33e9bc82fd8e6bb68203da"
# Redirect URI after GitLab authentication (must match the URI registered in GitLab application)
VITE_OAUTH2_REDIRECT_URL="http://localhost:8080/auth/login"

# Feature Flags
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_DEBUG_MODE=true

# Logging Configuration
VITE_LOG_LEVEL="debug"

# PWA Configuration
VITE_ENABLE_PWA=true

# Dev Server Configuration (optional)
VITE_DEV_PORT=8081
