  "scripts": {
    "sprites": "gulp sprites",
    "lint": "eslint \"./**/*.{js,vue}\" --config .eslintrc.js",
    "lintfix": "eslint \"./**/*.{js,vue}\" --config .eslintrc.js --fix",
    "local": "cross-env NODE_ENV=local NODE_OPTIONS=--max-old-space-size=8192 webpack-dev-server --open --config config/webpack/webpack.local.js",
    "test": "cross-env NODE_ENV=test BUILD_ID=$(date \"+%s\") NODE_OPTIONS=--max-old-space-size=8192 webpack --config config/webpack/webpack.deploy.js && rm ./dist/*.js.map",
    "staging": "cross-env NODE_ENV=staging NODE_OPTIONS=--max-old-space-size=8192 webpack --config config/webpack/webpack.deploy.js",
    "prod": "cross-env NODE_ENV=prod NODE_OPTIONS=--max-old-space-size=8192 webpack --config config/webpack/webpack.deploy.js",
    "jest": "jest --logHeapUsage -c jest.config.js",
    "local-jest": "npm run jest && npm run local",
    "test-jest": "npm run jest && npm run test",
    "staging-jest": "npm run jest && npm run staging",
    "prod-jest": "npm run jest && npm run prod",
    "postinstall": "patch-package"
  },
