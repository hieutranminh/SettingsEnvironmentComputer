{
  "name": "vue-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode localhost",
    "dev:localhost": "vite --mode localhost",
    "dev:development": "vite --mode development",
    "dev:staging": "vite --mode staging",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:localhost": "run-p type-check \"build-only --mode localhost\" --",
    "build:development": "run-p type-check \"build-only --mode development\" --",
    "build:staging": "run-p type-check \"build-only --mode staging\" --",
    "build:production": "run-p type-check \"build-only --mode production\" --",
    "preview": "vite preview",
    "preview:localhost": "vite preview --mode localhost",
    "preview:development": "vite preview --mode development",
    "preview:staging": "vite preview --mode staging",
    "preview:production": "vite preview --mode production",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:ci": "cross-env CI=true eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:format": "run-s lint format",
    "validate": "run-p type-check lint:check format:check",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@primeuix/themes": "^1.2.1",
    "@primevue/forms": "^4.3.6",
    "axios": "^1.11.0",
    "html2canvas": "^1.4.1",
    "js-cookie": "^3.0.5",
    "luxon": "^3.7.2",
    "pinia": "^3.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.6",
    "quill": "^2.0.3",
    "vue": "^3.5.17",
    "vue-currency-input": "^3.2.2",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.5.1",
    "xlsx": "^0.18.5",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@primevue/auto-import-resolver": "^4.3.6",
    "cross-env": "^7.0.3",
    "@tsconfig/node22": "^22.0.2",
    "@types/js-cookie": "^3.0.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.32",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/ui": "^4.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.29.0",
    "eslint-plugin-vue": "~10.2.0",
    "jiti": "^2.4.2",
    "jsdom": "^27.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.5.3",
    "sass": "^1.89.2",
    "typescript": "~5.8.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^5.4.21",
    "vite-plugin-checker": "^0.11.0",
    "vite-plugin-vue-devtools": "^7.7.7",
    "vitest": "^4.0.6",
    "vue-tsc": "^2.2.10"
  }
}
